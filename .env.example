APP_NAME=go_app
ENVIRONMENT=local #local|development|production
PORT=8080
DEBUG=true

# Railway Storage (S3-compatible)
OBJECT_ENDPOINT_URL=https://t3.storageapi.dev
OBJECT_REGION=auto
OBJECT_PUBLIC_BUCKET=your-public-bucket
OBJECT_REVIEW_BUCKET=your-review-bucket
OBJECT_PRIVATE_BUCKET=your-private-bucket
OBJECT_ACCESS_KEY_ID=tid_xxx
OBJECT_SECRET_ACCESS_KEY=tsec_xxx

# Railway Postgres (recommended)
DATABASE_SQL__DSN=postgresql://postgres:password@<railway-host>:<railway-port>/railway?sslmode=require

# Local Postgres (alternative)
# DATABASE_SQL__HOST=127.0.0.1
# DATABASE_SQL__PORT=5432
# DATABASE_SQL__DATABASE=postgres
# DATABASE_SQL__USERNAME=username
# DATABASE_SQL__PASSWORD=password

# DATABASE_REDIS__ADDR=127.0.0.1:6379
# DATABASE_REDIS__PASSWORD=
# DATABASE_REDIS__DB=0

OTEL_ENABLE=true

HTTP_JSON_NAMING=snake_case

KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CA_CERT_PATH=storage/cert/ca.crt
KAFKA_KEY_PATH=storage/cert/ca.crt
KAFKA_CERT_PATH_PATH=storage/cert/ca.crt
